# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ===== COLLABORATION: Local Configs, Credentials, Env files =====
# Each developer can have their own .env file
.env
.env.local
.env.*.local
android/local.properties
google-services.json

# Backend credentials (API keys, tokens) - NEVER commit these
*.key
*.pem
*.p12
*.pfx
*.crt

# Generated files per developer
pubspec.lock
*.g.dart

# OS-specific
.DS_Store
Thumbs.db

# Local IDE settings (VS Code workspace settings)
.vscode/launch.json
.vscode/settings.json

# Node/npm (if backend uses Node)
node_modules/
npm-debug.log
yarn-error.log

# Python (if backend uses Python)
__pycache__/
*.py[cod]
*$py.class
venv/
env/

# Temporary files
*.tmp
*.swp
*.swo
*~

