# Backend Configuration
# Backend developer tarafından doldurulacak
# BACKEND_API_URL=http://localhost:8080
# BACKEND_API_VERSION=v1

# MQTT Broker Configuration
# HiveMQ Cloud, EMQ, Eclipse Mosquitto vb. için
MQTT_BROKER=broker.hivemq.com
MQTT_TOPIC_SENSOR=agrotwin/sensorler
MQTT_TOPIC_COMMAND=agrotwin/komutlar
MQTT_WS_PATH=/mqtt
MQTT_PORTS=8884,443
MQTT_SECURE=true
MQTT_USE_WEBSOCKET=true

# NOTE: Bu dosya örnek; gerçek .env dosyası .gitignore'da gizlidir
# Her developer kendi test/production broker'ını ayarlayabilir
